#include <stdio.h>
#include <stdlib.h>
#include <limits.h>
#include <stdbool.h>

#define MAX_VERTICES 100

typedef struct {
    int adj[MAX_VERTICES][MAX_VERTICES];
    int num_vertices;
} Graph;

void graph_init(Graph *g, int num_vertices)
{
    g->num_vertices = num_vertices;
    for (int i = 0; i < num_vertices; i++) {
        for (int j = 0; j < num_vertices; j++) {
            g->adj[i][j] = 0;
        }
    }
}

void graph_add_edge(Graph *g, int src, int dest, int weight)
{
    g->adj[src][dest] = weight;
    g->adj[dest][src] = weight;
}

static int min_distance_vertex(const int *dist, const bool *visited, int n)
{
    int min = INT_MAX;
    int min_idx = -1;

    for (int v = 0; v < n; v++) {
        if (!visited[v] && dist[v] < min) {
            min = dist[v];
            min_idx = v;
        }
    }
    return min_idx;
}

void dijkstra(const Graph *g, int src, int *dist, int *prev)
{
    int n = g->num_vertices;
    bool visited[MAX_VERTICES];

    for (int i = 0; i < n; i++) {
        dist[i] = INT_MAX;
        prev[i] = -1;
        visited[i] = false;
    }
    dist[src] = 0;

    for (int count = 0; count < n - 1; count++) {
        int u = min_distance_vertex(dist, visited, n);
        if (u == -1)
            break;

        visited[u] = true;

        for (int v = 0; v < n; v++) {
            if (!visited[v] && g->adj[u][v] != 0 &&
                dist[u] != INT_MAX &&
                dist[u] + g->adj[u][v] < dist[v]) {
                dist[v] = dist[u] + g->adj[u][v];
                prev[v] = u;
            }
        }
    }
}

static void print_path(const int *prev, int dest)
{
    if (prev[dest] == -1) {
        printf("%d", dest);
        return;
    }
    print_path(prev, prev[dest]);
    printf(" -> %d", dest);
}

int main(void)
{
    Graph g;
    int dist[MAX_VERTICES];
    int prev[MAX_VERTICES];

    graph_init(&g, 6);

    graph_add_edge(&g, 0, 1, 4);
    graph_add_edge(&g, 0, 2, 1);
    graph_add_edge(&g, 1, 3, 1);
    graph_add_edge(&g, 2, 1, 2);
    graph_add_edge(&g, 2, 3, 5);
    graph_add_edge(&g, 3, 4, 3);
    graph_add_edge(&g, 4, 5, 1);
    graph_add_edge(&g, 3, 5, 6);

    int source = 0;
    dijkstra(&g, source, dist, prev);

    printf("Dijkstra's shortest paths from vertex %d:\n\n", source);
    printf("%-10s %-10s %s\n", "Vertex", "Distance", "Path");
    printf("---------- ---------- --------------------\n");

    for (int i = 0; i < g.num_vertices; i++) {
        if (dist[i] == INT_MAX) {
            printf("%-10d %-10s -\n", i, "INF");
        } else {
            printf("%-10d %-10d ", i, dist[i]);
            print_path(prev, i);
            printf("\n");
        }
    }

    return 0;
}
